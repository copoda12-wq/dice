<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<title>เกมทอยเต๋า</title>
<style>
body{
    font-family: Arial, sans-serif;
    text-align:center;
    background:#f4f6f8;
}

h1{
    margin-top:30px;
}

.dice-area{
    margin:30px auto;
    display:flex;
    flex-wrap:wrap;
    justify-content:center;
    gap:10px;
    max-width:600px;
}

.dice{
    width:60px;
    height:60px;
    background:white;
    border:2px solid #333;
    border-radius:10px;
    font-size:28px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-weight:bold;
}

button{
    padding:12px 25px;
    font-size:18px;
    border:none;
    border-radius:8px;
    background:#2563eb;
    color:white;
    cursor:pointer;
}

button:hover{
    background:#1d4ed8;
}

.result{
    margin-top:20px;
    font-size:20px;
    font-weight:bold;
}
</style>
</head>

<body>

<h1>🎲 เกมทอยเต๋า 9 ลูก</h1>

<button onclick="rollDice()">ทอยเต๋า</button>

<div class="dice-area" id="diceArea"></div>

<div class="result" id="result"></div>

<script>

function rollDice(){

    const area = document.getElementById("diceArea");
    const result = document.getElementById("result");

    area.innerHTML="";
    let dice = [];

    for(let i=0;i<9;i++){

        let value = Math.floor(Math.random()*6)+1;
        dice.push(value);

        let box = document.createElement("div");
        box.className="dice";
        box.innerText=value;

        area.appendChild(box);
    }

    let same = dice.every(v => v === dice[0]);

    if(same){
        result.innerText="🔥 เต๋าออกหน้าเดียวกันทั้งหมด!";
    }else{
        result.innerText="ลองใหม่!";
    }

}

</script>

</body>
</html>
